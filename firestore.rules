rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // user profiles — only the owner reads/writes their own document
    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /groups/{groupId} {
      function isMember() {
        return signedIn() &&
          request.auth.uid in resource.data.memberIds;
      }
      // a non-member may add ONLY themselves to memberIds (join via invite)
      function isSelfJoin() {
        return signedIn() &&
          request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
          request.resource.data.memberIds.removeAll(resource.data.memberIds) == [request.auth.uid];
      }

      allow read: if isMember() ||
        // allow reading by invite token lookup (query is constrained client-side)
        (signedIn() && resource.data.keys().hasAny(['inviteToken']));
      allow create: if signedIn() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.auth.uid in request.resource.data.memberIds;
      allow update: if isMember() || isSelfJoin();
      allow delete: if isMember();

      match /members/{memberId} {
        allow read: if signedIn();
        // members may write their own membership doc; admins can manage others
        allow write: if signedIn() && (
          request.auth.uid == memberId ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds
        );
      }

      match /subgroups/{subId} {
        allow read, write: if signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
      }

      match /events/{eventId} {
        allow read, write: if signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
      }
    }
  }
}
